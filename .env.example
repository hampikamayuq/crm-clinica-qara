PORT=3000
NODE_ENV=development

# Chave do painel/API interna. Em localhost pode ficar vazia; em producao e obrigatoria.
# A UI pedira essa chave quando o servidor responder 401.
ADMIN_API_KEY=

# Agente IA opcional. Use "openai" para respostas inteligentes ou "rules" para apenas fluxos importados.
AI_PROVIDER=rules
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

CLINIC_NAME=Clinica Qara
CLINIC_UNIT=Copacabana - RJ
# Valor padrao de fallback. Os valores por medico ficam em careTeam (server.js).
DEFAULT_CONSULT_VALUE=550

# Token livre definido por voce no painel da Meta para validar o webhook.
META_VERIFY_TOKEN=troque-este-token

# Obrigatorio em producao: valida X-Hub-Signature-256 dos webhooks.
META_APP_SECRET=

# Use apenas em teste local se voce realmente precisar aceitar webhook sem assinatura.
ALLOW_UNSIGNED_WEBHOOKS=false

# Versao da Graph API usada nas chamadas de envio.
META_GRAPH_VERSION=v23.0

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Instagram Messaging API
# Normalmente use o Page Access Token com permissao instagram_manage_messages.
INSTAGRAM_PAGE_ACCESS_TOKEN=

# Muitos apps enviam via /me/messages. Se seu setup exigir ID explicito, preencha.
INSTAGRAM_SEND_ID=me
